<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Chi tiết Bàn 5"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <LinearLayout
            android:id="@+id/boxDay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_table_type_selected"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            app:layout_constraintEnd_toStartOf="@id/boxHour"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/primary_blue" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NGÀY" android:textColor="@color/text_gray" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/boxHour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_table_type_selected"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            app:layout_constraintEnd_toStartOf="@id/boxMin"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/boxDay"
            app:layout_constraintTop_toTopOf="@id/boxDay">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="02" android:textColor="@color/primary_blue" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GIỜ" android:textColor="@color/text_gray" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/boxMin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_table_type_selected"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            app:layout_constraintEnd_toStartOf="@id/boxSec"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/boxHour"
            app:layout_constraintTop_toTopOf="@id/boxDay">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textColor="@color/primary_blue" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PHÚT" android:textColor="@color/text_gray" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/boxSec"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_table_type_selected"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/boxMin"
            app:layout_constraintTop_toTopOf="@id/boxDay">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="43" android:textColor="#2962FF" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GIÂY" android:textColor="#757575" android:textSize="10sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/badge"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/boxDay">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="● Đang hoạt động"
                android:textColor="@color/text_green"
                android:textSize="12sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTimeInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🕒 Bắt đầu: 14:30 "
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardStatus" />


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnThemDichVu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#2962FF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintWidth_percent="0.46"
            app:layout_constraintEnd_toStartOf="@+id/btnChuyenBan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTimeInfo">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_food" app:tint="@color/bg_white" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Thêm dịch vụ" android:textColor="@color/white" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đồ ăn, thuê gậy..." android:textColor="#B0BEC5" android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnChuyenBan"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@color/different_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintWidth_percent="0.46"
            app:layout_constraintBottom_toBottomOf="@id/btnThemDichVu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnThemDichVu"
            app:layout_constraintTop_toTopOf="@id/btnThemDichVu">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_move" app:tint="#1A237E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Chuyển bàn" android:textColor="@color/black" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đổi vị trí" android:textColor="@color/gray_2" android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnDongBan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFEBEE"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintWidth_percent="0.46"
            app:layout_constraintEnd_toStartOf="@+id/btnThanhToan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnThemDichVu">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:paddingVertical="14dp" android:text="🚫 Đóng bàn" android:textColor="#D32F2F" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnThanhToan"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintWidth_percent="0.46"
            app:layout_constraintBottom_toBottomOf="@id/btnDongBan"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnDongBan"
            app:layout_constraintTop_toTopOf="@id/btnDongBan">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:padding="16dp"
                android:layout_gravity="center"
                >
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_move" app:tint="@color/white" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"  android:text="Thanh toán" android:layout_marginLeft="10dp" android:textColor="@color/white" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/btnDongBan" />


        <TextView
            android:id="@+id/tvLabelList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:text="Danh sách dịch vụ"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:text="4 món"
            android:textColor="@color/gray_2"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvLabelList"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvLabelList" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrderItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvLabelList"
            tools:itemCount="3"
            tools:listitem="@layout/item_ordered_service" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#F8F9FA"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/rvOrderItems">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView android:id="@+id/lblTamTinh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tạm tính" android:textColor="@color/text_gray" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <TextView android:id="@+id/valTamTinh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="190.000đ" android:textColor="@color/black" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblTamTinh" />

                <TextView android:id="@+id/lblTienGio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Tiền giờ (2h 15p)" android:textColor="@color/text_gray" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/lblTamTinh" />
                <TextView android:id="@+id/valTienGio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="110.000đ" android:textColor="@color/black" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblTienGio" />

                <View android:id="@+id/divSummary" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="16dp" android:background="#E0E0E0" app:layout_constraintTop_toBottomOf="@id/lblTienGio" />

                <TextView android:id="@+id/lblTongCong" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Tổng cộng" android:textColor="@color/text_gray" android:textSize="16sp" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/divSummary" />
                <TextView android:id="@+id/valTongCong" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="300.000đ" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/lblTongCong" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblTongCong" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>