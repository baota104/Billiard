<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quản trị"
            android:textColor="@color/primary_blue"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/imgAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/imgAvatar" />

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyBan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:max="100"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgAvatar"

            app:adc_title="Quản lý Bàn"
            app:adc_subtitle="10 bàn đang hoạt động"
            app:adc_icon="@drawable/ic_table"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="true"
            app:adc_progressLabel="Tỉ lệ lấp đầy"
            app:adc_progressValue="65" />


        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyKhungGio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyBan"

            app:adc_title="Quản lý Giá &amp; Khung giờ"
            app:adc_subtitle="Cấu hình giá sáng, tối &amp; cuối tuần"
            app:adc_icon="@drawable/ic_time"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="false" />

        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyKhohang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyKhungGio"

            app:adc_title="Quản lý Kho hàng"
            app:adc_subtitle="15 mặt hàng sắp hết"
            app:adc_icon="@drawable/ic_inventory"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="true"
            app:adc_progressLabel="Trạng thái kho"
            app:adc_progressValue="85" />

        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyNhanVien"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyKhohang"

            app:adc_title="Quản lý Nhân viên"
            app:adc_subtitle="12 Nhân viên đang hoạt động"
            app:adc_icon="@drawable/ic_group"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="false" />

        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyVC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyNhanVien"

            app:adc_title="Quản lý Voucher"
            app:adc_subtitle="5 voucher đang hoạt động"
            app:adc_icon="@drawable/ic_voucher"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="true"
            app:adc_progressLabel="Tỉ lệ sử dụng"
            app:adc_progressValue="85" />
        <com.example.billiard.presentation.customview.AdminDashboardCard
            android:id="@+id/cardQuanLyBank"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyVC"

            app:adc_title="Quản lý Bank"
            app:adc_subtitle="3 tài khoản đang hoạt động"
            app:adc_icon="@drawable/ic_bank"
            app:adc_iconTint="@color/primary_blue"
            app:adc_showProgress="false" />
        <TextView
            android:id="@+id/tvTienIchTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Tiện ích"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardQuanLyBank" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardThongBao"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toStartOf="@+id/cardHoTro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTienIchTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#FF4081" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Thông báo"
                    android:textColor="@color/black"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHoTro"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardThongBao"
            app:layout_constraintTop_toBottomOf="@+id/tvTienIchTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_help"
                    app:tint="@color/help" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hỗ trợ"
                    android:textColor="@color/black"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>