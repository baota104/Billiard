<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"

    android:paddingBottom="24dp">

    <View
        android:id="@+id/viewDragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#E0E0E0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTableName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:textSize="22sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewDragHandle"
        tools:text="Bàn 02" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:cardBackgroundColor="@color/different_white"
        app:cardCornerRadius="50dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/tvTableName"
        app:layout_constraintStart_toEndOf="@id/tvTableName"
        app:layout_constraintTop_toTopOf="@id/tvTableName">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="TRỐNG"
            android:textColor="@color/empty_table"
            android:textSize="10sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_circle_cancel"
        android:padding="8dp"
        android:src="@drawable/ic_close"
        app:tint="@color/text_gray"
        app:layout_constraintBottom_toBottomOf="@id/tvTableName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTableName" />

    <TextView
        android:id="@+id/tvTableInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tvTableName"
        app:layout_constraintTop_toBottomOf="@id/tvTableName"
        tools:text="Sảnh chính • Giá: 80k/h" />

    <TextView
        android:id="@+id/tvLabelType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="LOẠI BÀN"
        android:textColor="@color/text_gray"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/tvTableName"
        app:layout_constraintTop_toBottomOf="@id/tvTableInfo" />

    <HorizontalScrollView
        android:id="@+id/scrollTypes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvLabelType">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvsnooker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_table_type_selected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Snooker"
                android:textColor="@color/text_gray"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvspool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_table_type_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Bida Lỗ"
                android:textColor="@color/text_gray" />
            <TextView
                android:id="@+id/tvphang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_table_type_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Phăng"
                android:textColor="@color/text_gray" />
            <TextView
                android:id="@+id/tvvip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_table_type_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Bàn VIP"
                android:textColor="@color/text_gray" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvLabelImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="HÌNH MINH HỌA"
        android:textColor="@color/text_gray"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/tvTableName"
        app:layout_constraintTop_toBottomOf="@id/scrollTypes" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgTablePreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintHeight_percent="0.35"
        android:src="@drawable/img_ban"
        app:layout_constraintTop_toBottomOf="@id/tvLabelImage"
        app:shapeAppearanceOverlay="@style/RoundedCornerImageStyle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:text="Bắt đầu ngay"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary_blue"
        app:cornerRadius="12dp"
        app:iconSize="30dp"
        app:icon="@drawable/ic_play"
        app:iconTint="@color/white"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/imgTablePreview" />
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Giờ bắt đầu sẽ được tính từ lúc bạn bấm nút"
        android:textColor="@color/text_gray"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnStart" />

</androidx.constraintlayout.widget.ConstraintLayout>