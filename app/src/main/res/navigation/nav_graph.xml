<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.billiard.presentation.splash.SplashFragment"
        android:label="SplashFragment" >
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.billiard.presentation.auth.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.billiard.presentation.home.homscreen.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_banDetailFragment"
            app:destination="@id/banDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/administraitorFragment"
        android:name="com.example.billiard.presentation.administrator.admin.AdministraitorFragment"
        android:label="fragment_administraitor"
        tools:layout="@layout/fragment_administraitor" >
        <action
            android:id="@+id/action_administraitorFragment_to_tableManageFragment"
            app:destination="@id/tableManageFragment" />
        <action
            android:id="@+id/action_administraitorFragment_to_timeSlotManagementFragmentFragment"
            app:destination="@id/timeSlotManagementFragmentFragment" />
        <action
            android:id="@+id/action_administraitorFragment_to_voucherFragment"
            app:destination="@id/voucherFragment" />
        <action
            android:id="@+id/action_administraitorFragment_to_employeeManagementFragment"
            app:destination="@id/employeeManagementFragment" />
    </fragment>
    <fragment
        android:id="@+id/stasticsFragment"
        android:name="com.example.billiard.presentation.stastics.StasticsFragment"
        android:label="fragment_stastics"
        tools:layout="@layout/fragment_stastics" />
    <fragment
        android:id="@+id/tableManageFragment"
        android:name="com.example.billiard.presentation.administrator.table.TableManagementFragment"
        android:label="TableManageFragment" />
    <fragment
        android:id="@+id/banDetailFragment"
        android:name="com.example.billiard.presentation.home.openingtable.BanDetailFragment"
        android:label="BanDetailFragment" >
        <action
            android:id="@+id/action_banDetailFragment_to_orderServiceFragment"
            app:destination="@id/orderServiceFragment" />
        <action
            android:id="@+id/action_banDetailFragment_to_paymentFragment"
            app:destination="@id/paymentFragment" />
    </fragment>
    <fragment
        android:id="@+id/orderServiceFragment"
        android:name="com.example.billiard.presentation.home.orderservice.OrderServiceFragment"
        android:label="OrderServiceFragment" />
    <fragment
        android:id="@+id/timeSlotManagementFragmentFragment"
        android:name="com.example.billiard.presentation.administrator.time.TimeSlotManagementFragmentFragment"
        android:label="TimeSlotManagementFragmentFragment" >
        <action
            android:id="@+id/action_timeSlotManagementFragmentFragment_to_timeSlotDetailFragment"
            app:destination="@id/timeSlotDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/timeSlotDetailFragment"
        android:name="com.example.billiard.presentation.administrator.time.detail.TimeSlotDetailFragment"
        android:label="TimeSlotDetailFragment" />
    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.billiard.presentation.home.payment.PaymentFragment"
        android:label="PaymentFragment" >
        <action
            android:id="@+id/action_paymentFragment_to_invoicePaymentFragment"
            app:destination="@id/invoicePaymentFragment" />
    </fragment>
    <fragment
        android:id="@+id/invoicePaymentFragment"
        android:name="com.example.billiard.presentation.home.payment.invoice.InvoicePaymentFragment"
        android:label="InvoicePaymentFragment" />
    <fragment
        android:id="@+id/voucherFragment"
        android:name="com.example.billiard.presentation.administrator.voucher.VoucherFragment"
        android:label="fragment_voucher"
        tools:layout="@layout/fragment_voucher" >
        <action
            android:id="@+id/action_voucherFragment_to_createVoucherFragment"
            app:destination="@id/createVoucherFragment" />
    </fragment>
    <fragment
        android:id="@+id/createVoucherFragment"
        android:name="com.example.billiard.presentation.administrator.voucher.createvoucher.CreateVoucherFragment"
        android:label="CreateVoucherFragment" />
    <fragment
        android:id="@+id/employeeManagementFragment"
        android:name="com.example.billiard.presentation.administrator.employee.EmployeeManagementFragment"
        android:label="EmployeeManagementFragment" />
</navigation>